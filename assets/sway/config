# OpenClaw OS — Sway Configuration

# Modifier key
set $mod Mod4

# Terminal & Browser
set $term foot
set $browser chromium

# Start OpenClaw shell on startup
exec openclaw-shell

# Start waybar
exec waybar -c /etc/openclaw/waybar/config.jsonc -s /etc/openclaw/waybar/style.css

# Keybindings
bindsym $mod+Return exec $term
bindsym $mod+b exec $browser
bindsym $mod+q kill
bindsym $mod+d exec $term  # TODO: replace with app launcher
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exit

# Focus
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

# Move windows
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Down move down

# Layouts
bindsym $mod+h splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle

# Workspace keybindings
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4

# Super+Space to toggle OpenClaw chat overlay
bindsym $mod+space exec pkill -SIGUSR1 openclaw-shell || true

# Resize mode
mode "resize" {
    bindsym Left resize shrink width 10px
    bindsym Right resize grow width 10px
    bindsym Up resize shrink height 10px
    bindsym Down resize grow height 10px
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Appearance — OpenClaw branding
# No title bars — waybar handles the taskbar, keybindings handle window controls
# CSD (client-side decorations) in GTK apps will follow the GTK theme
default_border pixel 2
default_floating_border pixel 2
gaps inner 8
gaps outer 4

# Colors: border, background, text, indicator, child_border
# Coral accent for focused windows
client.focused #ff4d4d #0a0f1a #f0f4ff #00e5cc #ff4d4d
client.unfocused #1a1a2e #050810 #5a6480 #1a1a2e #1a1a2e
client.focused_inactive #2a2a4e #050810 #8892b0 #2a2a4e #2a2a4e

# Output config
output * bg #050810 solid_color

# Input config
input type:touchpad {
    tap enabled
    natural_scroll enabled
}

input type:keyboard {
    xkb_options caps:escape
}

# Floating rules
for_window [app_id="openclaw-shell"] {
    # Shell runs fullscreen as the desktop background
}

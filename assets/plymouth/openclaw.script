# OpenClaw OS Plymouth Script Theme
# Dark background, centered logo, coral orbital spinner

# ── Background ──
Window.SetBackgroundTopColor(0.02, 0.03, 0.06);    # #050810
Window.SetBackgroundBottomColor(0.02, 0.03, 0.06);

# ── Logo ──
logo.image = Image("logo.png");
logo.sprite = Sprite(logo.image);
logo.sprite.SetX(Window.GetWidth() / 2 - logo.image.GetWidth() / 2);
logo.sprite.SetY(Window.GetHeight() / 2 - logo.image.GetHeight() / 2 - 40);
logo.sprite.SetZ(10);

# ── Spinner ──
NUM_FRAMES = 36;

for (i = 0; i < NUM_FRAMES; i++) {
    spinner[i].image = Image("spinner-" + StringToInteger(i) + ".png");
}

# Padded filename helper — Plymouth script doesn't have sprintf
# so we load by index with zero-padded names
fun get_spinner_frame(index) {
    prefix = "spinner-";
    if (index < 10)
        return Image(prefix + "00" + index + ".png");
    else
        return Image(prefix + "0" + index + ".png");
}

# Reload with proper names
for (i = 0; i < NUM_FRAMES; i++) {
    spinner[i].image = get_spinner_frame(i);
}

spinner.sprite = Sprite();
spinner.sprite.SetZ(11);
spinner.current_frame = 0;
spinner.ticks_per_frame = 2;  # slow down: advance every 2 ticks
spinner.tick_count = 0;

fun refresh_callback() {
    spinner.tick_count++;
    if (spinner.tick_count >= spinner.ticks_per_frame) {
        spinner.tick_count = 0;
        spinner.current_frame = (spinner.current_frame + 1) % NUM_FRAMES;
    }
    
    frame = spinner[spinner.current_frame].image;
    spinner.sprite.SetImage(frame);
    spinner.sprite.SetX(Window.GetWidth() / 2 - frame.GetWidth() / 2);
    spinner.sprite.SetY(Window.GetHeight() / 2 + 40);
}

Plymouth.SetRefreshFunction(refresh_callback);

# ── Password prompt (for encrypted disks) ──
fun display_password_callback(prompt, bullets) {
    # Simple bullet display for disk encryption password
    bullet_string = "";
    for (i = 0; i < bullets; i++)
        bullet_string += "*";
    
    pass.prompt_image = Image.Text(prompt, 0.53, 0.57, 0.69);  # text_secondary color
    pass.prompt_sprite = Sprite(pass.prompt_image);
    pass.prompt_sprite.SetX(Window.GetWidth() / 2 - pass.prompt_image.GetWidth() / 2);
    pass.prompt_sprite.SetY(Window.GetHeight() / 2 + 100);
    
    pass.bullet_image = Image.Text(bullet_string, 0.94, 0.96, 1.0);  # text_primary color
    pass.bullet_sprite = Sprite(pass.bullet_image);
    pass.bullet_sprite.SetX(Window.GetWidth() / 2 - pass.bullet_image.GetWidth() / 2);
    pass.bullet_sprite.SetY(Window.GetHeight() / 2 + 130);
}

Plymouth.SetDisplayPasswordFunction(display_password_callback);

# ── Hide messages/status (keep it clean) ──
fun message_callback(text) {
    # Intentionally blank — we want a clean boot
}

Plymouth.SetMessageFunction(message_callback);
